function doPost(e) {
  try {
    const action = String((e.parameter && e.parameter.action) || '').trim();
    if (action && action !== 'kgm210Submit') {
      return jsonOutput({ ok: false, message: 'unsupported_action' });
    }

    const payload = parsePayload(e);
    const validation = validateKgm210Payload(payload);
    if (!validation.ok) {
      appendLog(payload, '실패', validation.errors.join('; '));
      return jsonOutput({ ok: false, message: 'invalid_payload', errors: validation.errors });
    }

    const lock = LockService.getScriptLock();
    lock.waitLock(15000);
    try {
      const sheets = ensureSheets();
      const duplicate = findSubmissionRow(sheets.rawWide, payload.submissionId) > 0;
      if (duplicate) {
        appendLog(payload, '중복', '이미 저장된 제출ID');
        return jsonOutput({ ok: true, duplicate: true, submissionId: payload.submissionId });
      }

      const rows = buildRows(payload);
      sheets.rawWide.appendRow(rows.wide);
      if (rows.long.length > 0) {
        sheets.rawLong.getRange(sheets.rawLong.getLastRow() + 1, 1, rows.long.length, KGM210_LONG_HEADERS.length).setValues(rows.long);
      }
      appendLog(payload, '성공', '문항연구용 Google Sheets 저장 완료');
      return jsonOutput({
        ok: true,
        duplicate: false,
        submissionId: payload.submissionId,
        wideSheet: KGM210_SHEET_NAMES.rawWide,
        wideRows: 1,
        longSheet: KGM210_SHEET_NAMES.rawLong,
        longRows: rows.long.length
      });
    } finally {
      lock.releaseLock();
    }
  } catch (error) {
    appendLog(null, '실패', error && error.message ? error.message : String(error));
    return jsonOutput({ ok: false, message: 'server_error', error: String(error && error.message ? error.message : error) });
  }
}

function doGet(e) {
  const action = String((e.parameter && e.parameter.action) || '').trim();
  if (action === 'install-item-research-template') {
    return jsonOutput(installItemResearchTemplate());
  }
  if (action === 'export-wide-csv') {
    return csvOutput(sheetToCsv(ensureSheets().rawWide), 'kgm210_item_research_wide.csv');
  }
  if (action === 'export-long-csv') {
    return csvOutput(sheetToCsv(ensureSheets().rawLong), 'kgm210_item_research_long.csv');
  }
  if (action === 'export-log-csv') {
    return csvOutput(sheetToCsv(ensureSheets().log), 'kgm210_item_research_log.csv');
  }
  return jsonOutput({
    ok: true,
    service: 'KGM210 Google Sheets sync',
    templateVersion: KGM210_TEMPLATE_VERSION,
    sheets: KGM210_REQUIRED_SHEETS,
    actions: ['kgm210Submit', 'install-item-research-template', 'export-wide-csv', 'export-long-csv', 'export-log-csv']
  });
}

function installItemResearchTemplate() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) throw new Error('스프레드시트에 연결된 Apps Script에서 실행해야 합니다.');
  archiveLegacySheets(ss);
  const sheets = ensureSheets();
  styleWorkbook_(sheets);
  appendLog(null, '설치', '문항연구용 템플릿 설치/검수 완료');
  return {
    ok: true,
    templateVersion: KGM210_TEMPLATE_VERSION,
    requiredSheets: KGM210_REQUIRED_SHEETS,
    itemCount: KGM210_ITEM_MASTER.length,
    rawWideHeaders: KGM210_WIDE_HEADERS.length,
    rawLongHeaders: KGM210_LONG_HEADERS.length
  };
}

function parsePayload(e) {
  const raw = e && e.postData && e.postData.contents ? e.postData.contents : '';
  if (e.parameter && e.parameter.payload) return JSON.parse(e.parameter.payload);
  if (raw) return JSON.parse(raw);
  throw new Error('payload missing');
}

function validateKgm210Payload(payload) {
  const errors = [];
  if (!payload || typeof payload !== 'object') errors.push('payload object required');
  if (payload && payload.completed !== true) errors.push('completed=true required');
  if (payload && Number(payload.answerCount) !== 210) errors.push('answerCount=210 required');
  if (!payload || !payload.submissionId) errors.push('submissionId required');
  if (!payload || !payload.anonymousResearchId) errors.push('anonymousResearchId required');
  if (!payload || !payload.itemResponsesJson) errors.push('itemResponsesJson required');
  try {
    const items = JSON.parse(payload && payload.itemResponsesJson ? payload.itemResponsesJson : '[]');
    if (!Array.isArray(items) || items.length !== 210) errors.push('itemResponsesJson must contain 210 responses');
    const seen = {};
    items.forEach((item, index) => {
      const no = Number(item.no || item.questionNo || index + 1);
      const value = Number(item.value);
      if (!Number.isInteger(no) || no < 1 || no > 210) errors.push('invalid item no at response ' + (index + 1));
      if (seen[no]) errors.push('duplicate item no ' + no);
      seen[no] = true;
      if (!Number.isInteger(value) || value < 1 || value > 7) errors.push('invalid response value at item ' + no);
    });
  } catch (error) {
    errors.push('itemResponsesJson must be valid JSON');
  }
  return { ok: errors.length === 0, errors: unique_(errors) };
}

function ensureSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) throw new Error('스프레드시트에 연결된 Apps Script에서 실행해야 합니다.');

  const overview = ensureSheet(ss, KGM210_SHEET_NAMES.overview, [['구분', '내용', '비고']]);
  seedOverview(overview);
  const itemMaster = ensureSheet(ss, KGM210_SHEET_NAMES.itemMaster, [KGM210_ITEM_MASTER_HEADERS]);
  seedItemMaster(itemMaster);
  const itemReviewCvi = ensureSheet(ss, KGM210_SHEET_NAMES.itemReviewCvi, [['문항번호', '문항코드', '영역', '과정', 'Z지표', '문항내용', '전문가1_적합도(1-4)', '전문가2_적합도(1-4)', '전문가3_적합도(1-4)', 'I-CVI', '명료성(1-4)', '행동기준(1-4)', '강도(1-4)', '사회적바람직성위험(1-4)', '수정권고', '수정안', '최종판정']]);
  seedItemReviewCvi(itemReviewCvi);
  const rawWide = ensureSheet(ss, KGM210_SHEET_NAMES.rawWide, [KGM210_WIDE_HEADERS]);
  const rawLong = ensureSheet(ss, KGM210_SHEET_NAMES.rawLong, [KGM210_LONG_HEADERS]);
  seedRawLongTemplate(rawLong);
  const itemAnalysis = ensureSheet(ss, KGM210_SHEET_NAMES.itemAnalysis, [KGM210_ITEM_ANALYSIS_HEADERS]);
  seedItemAnalysis(itemAnalysis);
  const scaleCodebook = ensureSheet(ss, KGM210_SHEET_NAMES.scaleCodebook, [['값', '라벨', '연구 해석 메모']]);
  seedScaleCodebook(scaleCodebook);
  const constructMap = ensureSheet(ss, KGM210_SHEET_NAMES.constructMap, [['구분', '코드', '명칭', '정의', '문항수', '검증가능 분석사인']]);
  seedConstructMap(constructMap);
  const validationPlan = ensureSheet(ss, KGM210_SHEET_NAMES.validationPlan, [['단계', '분석명', '목적', '권장 표본/조건', '산출물', '판정 기준/메모']]);
  seedValidationPlan(validationPlan);
  const payloadMap = ensureSheet(ss, KGM210_SHEET_NAMES.payloadMap, [['Payload key', '스프레드시트 필드', '유형', '필수', '연구용도', '비고']]);
  seedPayloadMap(payloadMap);
  const lists = ensureSheet(ss, KGM210_SHEET_NAMES.lists, [['scale', 'sample_group', 'age_band', 'gender', 'occupation', 'test_purpose', 'coaching_experience', 'research_status', 'api_status', 'spreadsheet_sync', 'review_1to4', 'final_decision']]);
  seedLists(lists);
  const log = ensureSheet(ss, KGM210_SHEET_NAMES.log, [KGM210_LOG_HEADERS]);
  return { ss, overview, itemMaster, itemReviewCvi, rawWide, rawLong, itemAnalysis, scaleCodebook, constructMap, validationPlan, payloadMap, lists, log };
}

function ensureSheet(ss, name, rows) {
  let sheet = ss.getSheetByName(name);
  if (!sheet) sheet = ss.insertSheet(name);
  if (sheet.getLastRow() === 0 && rows && rows.length) {
    sheet.getRange(1, 1, rows.length, rows[0].length).setValues(rows);
    sheet.setFrozenRows(1);
  }
  return sheet;
}

function archiveLegacySheets(ss) {
  const stamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyyMMdd_HHmmss');
  ['KGM210_Wide', 'KGM210_Long', 'KGM210_Log'].forEach(function(name) {
    const sheet = ss.getSheetByName(name);
    if (sheet) sheet.setName('archive_before_item_research_v1_' + stamp + '_' + name);
  });
}

function resetSheet_(sheet, rows) {
  sheet.clear();
  if (rows && rows.length) {
    sheet.getRange(1, 1, rows.length, rows[0].length).setValues(rows);
    sheet.setFrozenRows(1);
  }
}

